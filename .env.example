# --- Server ---
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# --- Mongo ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=org_chatbot

# Optional tenant scoping (if you store tenantId in docs)
DEFAULT_TENANT_ID=client-105

# --- Gemini ---
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-1.5-flash

# If true, use Gemini for response formatting too
USE_LLM_FORMATTER=false
